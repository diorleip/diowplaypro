generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())

  username    String   @unique
  password    String

  createdAt   DateTime @default(now())

  status      String   @default("ATIVO")
  role        String?  @default("user")

  indicadoPor String?

  nome        String?
  whatsapp    String?
  email       String?

  plano       String?  @default("30 Dias")

  expiraEm    DateTime?
}
model Banner {
  id        String   @id @default(cuid())
  title     String
  image     String
  createdAt DateTime @default(now())
}
